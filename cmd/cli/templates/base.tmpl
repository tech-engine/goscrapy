package {{.}}

import (
	"context"

	"github.com/tech-engine/goscrapy/cmd/gos"
)

type Spider struct {
	gos.ICoreSpider[*Record]
}

// New initializes the spider with minimal setup (no TUI, no stats collection).
func New(ctx context.Context) (*Spider, <-chan error) {
	app := gos.NewApp[*Record]().
		Setup(MIDDLEWARES, PIPELINES)

	// To enable stats collection, uncomment the following:
	// app.Scheduler.WithStatsRecorderFactory(HttpStats)
	// app.Telemetry().AddCollector(HttpStats)
	// app.Engine.WithOnShutdown(func() { HttpStats.Print() })

	// To enable TUI, also uncomment the following (and update Start logic):
	// dashboard := tui.New(app.Logger())
	// app.Telemetry().AddObserver(dashboard)

	spider := &Spider{
		ICoreSpider: app,
	}

	errCh := make(chan error, 1)
	go func() {
		errCh <- app.Start(ctx)
		spider.Close(ctx)
	}()

	return spider, errCh
}
