package {{.}}

import (
	"context"

	"github.com/tech-engine/goscrapy/pkg/gos"
)

type Spider struct {
	gos.ICoreSpider[*Record]
}

// New initializes the spider with minimal setup (no TUI, no stats collection).
func New(ctx context.Context) *Spider {
	app := gos.New[*Record]().
		WithMiddlewares(MIDDLEWARES...).
		WithPipelines(PIPELINES...)

	// To enable stats collection & TUI, uncomment the following:
	// hub := ts.NewTelemetryHub()
	// hub.AddCollector(HttpStats)
	//
	// dashboard := tui.New(app.Logger())
	// hub.AddObserver(dashboard)
	//
	// app.WithStatsRecorderFactory(HttpStats).
	// 	WithTelemetry(hub).
	// 	WithOnEngineShutdown(func() { HttpStats.Print() })

	spider := &Spider{
		ICoreSpider: app,
	}

	go func() {
		_ = app.Start(ctx)
		spider.Close(ctx)
	}()

	return spider
}
